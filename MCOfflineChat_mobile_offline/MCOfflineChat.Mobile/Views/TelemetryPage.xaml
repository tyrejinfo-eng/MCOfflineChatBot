<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MCOfflineChat.Mobile.ViewModels"
             xmlns:models="clr-namespace:MCOfflineChat.Mobile.Models"
             x:Class="MCOfflineChat.Mobile.Views.TelemetryPage"
             x:DataType="vm:TelemetryViewModel"
             BackgroundColor="{StaticResource BackgroundColor}"
             Title="Telemetry Scanner">
    <Grid RowDefinitions="Auto,Auto,*" Padding="16">
        <VerticalStackLayout Grid.Row="0" Spacing="8">
            <Label Text="TELEMETRY" Style="{StaticResource NeonTitleLabel}" Margin="0,4,0,0"/>
            <Label Text="{Binding StatusText}" TextColor="{StaticResource TextMutedColor}" FontSize="13"/>
            <Button Text="Scan Device" Command="{Binding ScanCommand}"
                    IsEnabled="{Binding IsScanning, Converter={StaticResource InvertedBoolConverter}}"
                    Style="{StaticResource PrimaryButton}" HeightRequest="40"/>
            <ActivityIndicator IsRunning="{Binding IsScanning}" IsVisible="{Binding IsScanning}"
                             Color="{StaticResource AccentColor}" HeightRequest="20"/>
        </VerticalStackLayout>

        <!-- Stats -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*,*" Margin="0,8">
            <Frame BackgroundColor="{StaticResource SurfaceColor}" CornerRadius="8" Padding="8" Margin="0,0,4,0" BorderColor="Transparent">
                <VerticalStackLayout HorizontalOptions="Center">
                    <Label Text="{Binding TotalFound}" TextColor="{StaticResource AccentColor}" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center"/>
                    <Label Text="Total" TextColor="{StaticResource TextMutedColor}" FontSize="11" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>
            <Frame Grid.Column="1" BackgroundColor="{StaticResource SurfaceColor}" CornerRadius="8" Padding="8" Margin="2,0" BorderColor="Transparent">
                <VerticalStackLayout HorizontalOptions="Center">
                    <Label Text="{Binding HighThreatCount}" TextColor="{StaticResource RedColor}" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center"/>
                    <Label Text="High Threat" TextColor="{StaticResource TextMutedColor}" FontSize="11" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>
            <Frame Grid.Column="2" BackgroundColor="{StaticResource SurfaceColor}" CornerRadius="8" Padding="8" Margin="4,0,0,0" BorderColor="Transparent">
                <VerticalStackLayout HorizontalOptions="Center">
                    <Label Text="{Binding RunningCount}" TextColor="{StaticResource YellowColor}" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center"/>
                    <Label Text="Running" TextColor="{StaticResource TextMutedColor}" FontSize="11" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>
        </Grid>

        <!-- Filter + List -->
        <Grid Grid.Row="2" RowDefinitions="Auto,*">
            <ScrollView Grid.Row="0" Orientation="Horizontal" Margin="0,4,0,8">
                <HorizontalStackLayout Spacing="6">
                    <Button Text="All" FontSize="11" HeightRequest="30" Padding="10,0" CornerRadius="15"
                            BackgroundColor="{StaticResource SurfaceLightColor}" TextColor="{StaticResource TextColor}"
                            Command="{Binding FilterByCommand}" CommandParameter="All"/>
                    <Button Text="Audio" FontSize="11" HeightRequest="30" Padding="10,0" CornerRadius="15"
                            BackgroundColor="{StaticResource SurfaceLightColor}" TextColor="{StaticResource TextColor}"
                            Command="{Binding FilterByCommand}" CommandParameter="Audio"/>
                    <Button Text="Camera" FontSize="11" HeightRequest="30" Padding="10,0" CornerRadius="15"
                            BackgroundColor="{StaticResource SurfaceLightColor}" TextColor="{StaticResource TextColor}"
                            Command="{Binding FilterByCommand}" CommandParameter="Camera"/>
                    <Button Text="Location" FontSize="11" HeightRequest="30" Padding="10,0" CornerRadius="15"
                            BackgroundColor="{StaticResource SurfaceLightColor}" TextColor="{StaticResource TextColor}"
                            Command="{Binding FilterByCommand}" CommandParameter="Location"/>
                    <Button Text="High Risk" FontSize="11" HeightRequest="30" Padding="10,0" CornerRadius="15"
                            BackgroundColor="{StaticResource RedColor}" TextColor="White"
                            Command="{Binding FilterByCommand}" CommandParameter="High"/>
                </HorizontalStackLayout>
            </ScrollView>

            <CollectionView Grid.Row="1" ItemsSource="{Binding Items}">
                <CollectionView.EmptyView>
                    <Label Text="Tap 'Scan Device' to detect telemetry collectors."
                           TextColor="{StaticResource TextMutedColor}" HorizontalOptions="Center" Margin="0,40"/>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:TelemetryItem">
                        <Frame BackgroundColor="{StaticResource SurfaceColor}" CornerRadius="8"
                               Padding="12" Margin="0,3" BorderColor="Transparent">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto">
                                <Label Grid.Row="0" Text="{Binding AppName}" TextColor="{StaticResource TextColor}"
                                       FontSize="15" FontAttributes="Bold"/>
                                <Label Grid.Row="0" Grid.Column="1" Text="{Binding ThreatLevel}" FontSize="12"
                                       TextColor="{StaticResource RedColor}" VerticalOptions="Center"/>
                                <Label Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding PackageName}"
                                       TextColor="{StaticResource TextMutedColor}" FontSize="11"/>
                                <HorizontalStackLayout Grid.Row="2" Grid.ColumnSpan="2" Spacing="8">
                                    <Label Text="{Binding Category}" TextColor="{StaticResource YellowColor}" FontSize="12"/>
                                    <Label Text="{Binding DataCollectionType, StringFormat='Collects: {0}'}"
                                           TextColor="{StaticResource TextMutedColor}" FontSize="11"/>
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Grid.Row="3" Grid.ColumnSpan="2" Spacing="6" Margin="0,6,0,0">
                                    <Button Text="Kill" FontSize="11" HeightRequest="30" Padding="8,0"
                                            BackgroundColor="{StaticResource RedColor}" TextColor="White"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TelemetryViewModel}}, Path=KillAppCommand}"
                                            CommandParameter="{Binding .}"/>
                                    <Button Text="Settings" FontSize="11" HeightRequest="30" Padding="8,0"
                                            BackgroundColor="{StaticResource SurfaceLightColor}" TextColor="{StaticResource TextColor}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TelemetryViewModel}}, Path=OpenSettingsCommand}"
                                            CommandParameter="{Binding .}"/>
                                </HorizontalStackLayout>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>
