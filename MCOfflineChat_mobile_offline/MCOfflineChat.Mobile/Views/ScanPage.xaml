<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MCOfflineChat.Mobile.ViewModels"
             xmlns:models="clr-namespace:MCOfflineChat.Mobile.Models"
             x:Class="MCOfflineChat.Mobile.Views.ScanPage"
             x:DataType="vm:ScanViewModel"
             Title="Scanner"
             BackgroundColor="{StaticResource BackgroundColor}">

    <Grid RowDefinitions="Auto,*" Padding="16">

        <!-- Top Controls -->
        <VerticalStackLayout Grid.Row="0" Spacing="12">

            <Label Text="THREAT SCANNER"
                   Style="{StaticResource NeonTitleLabel}"
                   Margin="0,8,0,0" />

            <!-- Scan Type Selection -->
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Scan Type"
                           TextColor="{StaticResource AccentColor}"
                           FontSize="14"
                           FontAttributes="Bold" />
                    <Picker ItemsSource="{Binding ScanTypes}"
                            SelectedItem="{Binding SelectedScanType}"
                            TextColor="{StaticResource TextColor}"
                            BackgroundColor="{StaticResource SurfaceColor}"
                            FontSize="16"
                            IsEnabled="{Binding IsScanning, Converter={StaticResource InvertedBoolConverter}}" />
                </VerticalStackLayout>
            </Frame>

            <!-- Action Buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Grid.Column="0"
                        Text="Start Scan"
                        Command="{Binding StartScanCommand}"
                        Style="{StaticResource PrimaryButton}"
                        IsVisible="{Binding IsScanning, Converter={StaticResource InvertedBoolConverter}}" />

                <Button Grid.Column="0"
                        Text="Stop Scan"
                        Command="{Binding StopScanCommand}"
                        Style="{StaticResource DangerButton}"
                        IsVisible="{Binding IsScanning}" />

                <Button Grid.Column="1"
                        Text="Clear"
                        Command="{Binding ClearResultsCommand}"
                        Style="{StaticResource SecondaryButton}"
                        IsEnabled="{Binding IsScanning, Converter={StaticResource InvertedBoolConverter}}" />
            </Grid>

            <!-- Progress Section -->
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="8">
                    <ProgressBar Progress="{Binding ScanProgress}"
                                 ProgressColor="{StaticResource AccentColor}" />

                    <Label Text="{Binding ScanStatusText}"
                           Style="{StaticResource MutedLabel}"
                           LineBreakMode="TailTruncation" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="Files Scanned"
                                   Style="{StaticResource MutedLabel}" />
                            <Label Text="{Binding FilesScanned}"
                                   Style="{StaticResource BodyLabel}"
                                   TextColor="{StaticResource AccentColor}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="Threats Found"
                                   Style="{StaticResource MutedLabel}" />
                            <Label Text="{Binding ThreatsFound}"
                                   Style="{StaticResource BodyLabel}"
                                   TextColor="{StaticResource RedColor}" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>

        <!-- Results List -->
        <CollectionView Grid.Row="1"
                         ItemsSource="{Binding Results}"
                         Margin="0,12,0,0">
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Padding="32">
                    <Label Text="No threats detected"
                           Style="{StaticResource MutedLabel}"
                           HorizontalTextAlignment="Center"
                           FontSize="16" />
                    <Label Text="Run a scan to check for threats"
                           Style="{StaticResource MutedLabel}"
                           HorizontalTextAlignment="Center"
                           Margin="0,4,0,0" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ScanResultItem">
                    <Frame Style="{StaticResource CardFrame}" Margin="0,4">
                        <VerticalStackLayout Spacing="8">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Ellipse Grid.Column="0"
                                         WidthRequest="10"
                                         HeightRequest="10"
                                         Fill="{StaticResource RedColor}"
                                         VerticalOptions="Center" />

                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                    <Label Text="{Binding ThreatName}"
                                           TextColor="{StaticResource RedColor}"
                                           FontSize="14"
                                           FontAttributes="Bold" />
                                    <Label Text="{Binding FileName}"
                                           TextColor="{StaticResource TextColor}"
                                           FontSize="13" />
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding Severity, StringFormat='Severity: {0}'}"
                                               TextColor="{StaticResource YellowColor}"
                                               FontSize="11" />
                                        <Label Text="{Binding DetectedAt, StringFormat='{0:HH:mm:ss}'}"
                                               TextColor="{StaticResource TextMutedColor}"
                                               FontSize="11" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Action Buttons -->
                            <HorizontalStackLayout Spacing="8"
                                                   HorizontalOptions="End">
                                <Button Text="Kill"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ScanViewModel}}, Path=KillThreatCommand}"
                                        CommandParameter="{Binding .}"
                                        Style="{StaticResource DangerButton}"
                                        HeightRequest="30"
                                        FontSize="11"
                                        Padding="10,0" />
                                <Button Text="Remove"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ScanViewModel}}, Path=RemoveThreatCommand}"
                                        CommandParameter="{Binding .}"
                                        Style="{StaticResource DangerButton}"
                                        HeightRequest="30"
                                        FontSize="11"
                                        Padding="10,0" />
                                <Button Text="Info"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ScanViewModel}}, Path=OpenAppInfoCommand}"
                                        CommandParameter="{Binding .}"
                                        Style="{StaticResource SecondaryButton}"
                                        HeightRequest="30"
                                        FontSize="11"
                                        Padding="10,0" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>
