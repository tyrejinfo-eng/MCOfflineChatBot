<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MCOfflineChat.Mobile.ViewModels"
             x:Class="MCOfflineChat.Mobile.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="Settings"
             BackgroundColor="{StaticResource BackgroundColor}">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="16">
            <Label Text="SETTINGS" Style="{StaticResource NeonTitleLabel}" Margin="0,8,0,4" />
            <Label Text="{Binding StatusMessage}" Style="{StaticResource MutedLabel}" />

            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Offline Model Manager" TextColor="{StaticResource AccentColor}" FontSize="16" FontAttributes="Bold" />
                    <Label Text="{Binding ModelDirectory, StringFormat='Model folder: {0}'}" Style="{StaticResource MutedLabel}" />
                    <Picker ItemsSource="{Binding DownloadedModels}"
                            SelectedItem="{Binding SelectedLlmModel}"
                            TextColor="{StaticResource TextColor}"
                            BackgroundColor="{StaticResource SurfaceColor}"
                            Title="Select a local model" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Text="Import GGUF Model"
                                Command="{Binding ImportModelCommand}"
                                Style="{StaticResource PrimaryButton}" />
                        <Button Grid.Column="1" Text="Refresh Local Models"
                                Command="{Binding RefreshModelsCommand}"
                                Style="{StaticResource SecondaryButton}" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Assistant" TextColor="{StaticResource AccentColor}" FontSize="16" FontAttributes="Bold" />

                    <Entry Text="{Binding AssistantName}"
                           Placeholder="Assistant name"
                           TextColor="{StaticResource TextColor}"
                           PlaceholderColor="{StaticResource TextMutedColor}"
                           BackgroundColor="{StaticResource SurfaceColor}" />

                    <Editor Text="{Binding SystemPrompt}"
                            AutoSize="TextChanges"
                            HeightRequest="130"
                            Placeholder="Custom prompt"
                            TextColor="{StaticResource TextColor}"
                            BackgroundColor="{StaticResource SurfaceColor}" />

                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="12" ColumnSpacing="12">
                        <Label Grid.Row="0" Text="Notifications" Style="{StaticResource BodyLabel}" VerticalTextAlignment="Center" />
                        <Switch Grid.Row="0" Grid.Column="1" IsToggled="{Binding NotificationsEnabled}" />

                        <Label Grid.Row="1" Text="Text-to-speech" Style="{StaticResource BodyLabel}" VerticalTextAlignment="Center" />
                        <Switch Grid.Row="1" Grid.Column="1" IsToggled="{Binding TtsEnabled}" />

                        <Label Grid.Row="2" Text="Creative mode" Style="{StaticResource BodyLabel}" VerticalTextAlignment="Center" />
                        <Switch Grid.Row="2" Grid.Column="1" IsToggled="{Binding CreativeMode}" />
                    </Grid>

                    <Label Text="Offline mode stays on by default." Style="{StaticResource MutedLabel}" />
                    <Switch IsToggled="{Binding UseOfflineMode}" />
                </VerticalStackLayout>
            </Frame>

            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Language" TextColor="{StaticResource AccentColor}" FontSize="16" FontAttributes="Bold" />
                    <Picker ItemsSource="{Binding SupportedLanguages}"
                            SelectedItem="{Binding SelectedLanguage}"
                            TextColor="{StaticResource TextColor}"
                            BackgroundColor="{StaticResource SurfaceColor}"
                            Title="Choose a language" />
                    <Label Text="{Binding VersionDisplay, StringFormat='Version: {0}'}" Style="{StaticResource MutedLabel}" />
                    <Button Text="Reset Offline Defaults" Command="{Binding ResetOfflineDefaultsCommand}" Style="{StaticResource SecondaryButton}" />
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
