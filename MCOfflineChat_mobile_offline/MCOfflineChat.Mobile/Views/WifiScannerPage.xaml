<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MCOfflineChat.Mobile.ViewModels"
             xmlns:models="clr-namespace:MCOfflineChat.Mobile.Models"
             x:Class="MCOfflineChat.Mobile.Views.WifiScannerPage"
             x:DataType="vm:WifiScannerViewModel"
             BackgroundColor="{StaticResource BackgroundColor}"
             Title="WiFi Scanner">
    <Grid RowDefinitions="Auto,*,Auto" Padding="16">
        <VerticalStackLayout Grid.Row="0" Spacing="8">
            <Label Text="WIFI SCANNER" Style="{StaticResource NeonTitleLabel}" Margin="0,4,0,0"/>
            <Label Text="{Binding StatusText}" TextColor="{StaticResource TextMutedColor}" FontSize="13"/>
            <HorizontalStackLayout Spacing="8">
                <Button Text="Scan Networks" Command="{Binding ScanCommand}"
                        IsEnabled="{Binding IsScanning, Converter={StaticResource InvertedBoolConverter}}"
                        Style="{StaticResource PrimaryButton}" HeightRequest="40"/>
                <Button Text="Trace Route" Command="{Binding TraceRouteCommand}"
                        IsEnabled="{Binding IsTracing, Converter={StaticResource InvertedBoolConverter}}"
                        Style="{StaticResource SecondaryButton}" HeightRequest="40"/>
            </HorizontalStackLayout>
            <ActivityIndicator IsRunning="{Binding IsScanning}" IsVisible="{Binding IsScanning}"
                             Color="{StaticResource AccentColor}" HeightRequest="20"/>
        </VerticalStackLayout>

        <ScrollView Grid.Row="1" Margin="0,8,0,0">
            <VerticalStackLayout Spacing="4">
                <CollectionView ItemsSource="{Binding Networks}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:WifiNetworkInfo">
                            <Frame BackgroundColor="{StaticResource SurfaceColor}" CornerRadius="8"
                                   Padding="12" Margin="0,4" BorderColor="Transparent">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                                    <HorizontalStackLayout Grid.Row="0" Spacing="8">
                                        <Label Text="{Binding Ssid}" TextColor="{StaticResource TextColor}"
                                               FontSize="16" FontAttributes="Bold"/>
                                        <Label Text="(Connected)" TextColor="{StaticResource GreenColor}" FontSize="12"
                                               IsVisible="{Binding IsCurrentNetwork}" VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                    <Label Grid.Row="0" Grid.Column="1" Text="{Binding Band}"
                                           TextColor="{StaticResource AccentColor}" FontSize="12" VerticalOptions="Center"/>
                                    <HorizontalStackLayout Grid.Row="1" Grid.ColumnSpan="2" Spacing="12">
                                        <Label Text="{Binding SecurityType}" TextColor="{StaticResource YellowColor}" FontSize="12"/>
                                        <Label Text="{Binding SignalStrength}" TextColor="{StaticResource TextMutedColor}" FontSize="12"/>
                                        <Label Text="{Binding SecurityRating}" FontSize="12"
                                               TextColor="{StaticResource TextMutedColor}"/>
                                    </HorizontalStackLayout>
                                    <Button Grid.Row="2" Grid.ColumnSpan="2" Text="Test Connection" FontSize="11"
                                            HeightRequest="32" Padding="8,0" Margin="0,6,0,0" HorizontalOptions="Start"
                                            BackgroundColor="{StaticResource AccentColor}" TextColor="#1A1610"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WifiScannerViewModel}}, Path=TestConnectionCommand}"
                                            CommandParameter="{Binding .}"/>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Test Result -->
                <Frame BackgroundColor="{StaticResource SurfaceColor}" CornerRadius="8"
                       Padding="12" Margin="0,8" BorderColor="Transparent"
                       IsVisible="{Binding TestResult, Converter={StaticResource IsNotNullOrEmptyConverter}}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Connection Test Result" TextColor="{StaticResource AccentColor}" FontAttributes="Bold"/>
                        <Label Text="{Binding TestResult}" TextColor="{StaticResource TextColor}" FontSize="13"
                               FontFamily="monospace"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Trace Route -->
                <Frame BackgroundColor="{StaticResource SurfaceColor}" CornerRadius="8"
                       Padding="12" BorderColor="Transparent">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Network Trace" TextColor="{StaticResource AccentColor}" FontAttributes="Bold"/>
                        <ActivityIndicator IsRunning="{Binding IsTracing}" IsVisible="{Binding IsTracing}" HeightRequest="20"/>
                        <CollectionView ItemsSource="{Binding TraceHops}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Label Text="{Binding .}" TextColor="{StaticResource TextColor}"
                                           FontSize="12" FontFamily="monospace" Margin="0,2"/>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
