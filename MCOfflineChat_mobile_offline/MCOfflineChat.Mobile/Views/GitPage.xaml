<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MCOfflineChat.Mobile.ViewModels"
             xmlns:models="clr-namespace:MCOfflineChat.Mobile.Models"
             x:Class="MCOfflineChat.Mobile.Views.GitPage"
             x:DataType="vm:GitViewModel"
             BackgroundColor="{StaticResource BackgroundColor}"
             Title="Git Repos">
    <Grid RowDefinitions="Auto,*" Padding="16">
        <VerticalStackLayout Grid.Row="0" Spacing="8">
            <Label Text="GIT REPOS" Style="{StaticResource NeonTitleLabel}" Margin="0,4,0,0"/>
            <Label Text="{Binding StatusText}" TextColor="{StaticResource TextMutedColor}" FontSize="13"/>

            <!-- Search bar -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,4">
                <Entry Text="{Binding SearchQuery}" Placeholder="Search GitHub repositories..."
                       PlaceholderColor="{StaticResource TextMutedColor}"
                       TextColor="{StaticResource TextColor}" BackgroundColor="{StaticResource SurfaceColor}"
                       ReturnCommand="{Binding SearchCommand}"/>
                <Button Grid.Column="1" Text="Search" Command="{Binding SearchCommand}"
                        BackgroundColor="{StaticResource AccentColor}" TextColor="#1A1610"
                        HeightRequest="40" WidthRequest="80" Margin="4,0,0,0"/>
            </Grid>

            <!-- Tab buttons -->
            <HorizontalStackLayout Spacing="6">
                <Button Text="Search" FontSize="12" HeightRequest="32" Padding="10,0" CornerRadius="16"
                        BackgroundColor="{StaticResource SurfaceLightColor}" TextColor="{StaticResource TextColor}"
                        Command="{Binding SwitchTabCommand}" CommandParameter="Search"/>
                <Button Text="Browse" FontSize="12" HeightRequest="32" Padding="10,0" CornerRadius="16"
                        BackgroundColor="{StaticResource SurfaceLightColor}" TextColor="{StaticResource TextColor}"
                        Command="{Binding SwitchTabCommand}" CommandParameter="Browse"/>
                <Button Text="Local" FontSize="12" HeightRequest="32" Padding="10,0" CornerRadius="16"
                        BackgroundColor="{StaticResource SurfaceLightColor}" TextColor="{StaticResource TextColor}"
                        Command="{Binding LoadLocalReposCommand}"/>
            </HorizontalStackLayout>
            <ActivityIndicator IsRunning="{Binding IsSearching}" IsVisible="{Binding IsSearching}"
                             Color="{StaticResource AccentColor}" HeightRequest="20"/>
        </VerticalStackLayout>

        <ScrollView Grid.Row="1" Margin="0,8,0,0">
            <VerticalStackLayout Spacing="4">
                <!-- Search Results -->
                <VerticalStackLayout IsVisible="False">
                    <VerticalStackLayout.Triggers>
                        <DataTrigger TargetType="VerticalStackLayout" Binding="{Binding SelectedTab}" Value="Search">
                            <Setter Property="IsVisible" Value="True"/>
                        </DataTrigger>
                    </VerticalStackLayout.Triggers>
                    <CollectionView ItemsSource="{Binding SearchResults}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:GitRepoInfo">
                                <Frame BackgroundColor="{StaticResource SurfaceColor}" CornerRadius="8"
                                       Padding="12" Margin="0,3" BorderColor="Transparent">
                                    <Grid RowDefinitions="Auto,Auto,Auto,Auto">
                                        <Label Grid.Row="0" Text="{Binding FullName}" TextColor="{StaticResource TextColor}"
                                               FontSize="15" FontAttributes="Bold"/>
                                        <Label Grid.Row="1" Text="{Binding Description}" TextColor="{StaticResource TextMutedColor}"
                                               FontSize="12" MaxLines="2" LineBreakMode="TailTruncation"/>
                                        <HorizontalStackLayout Grid.Row="2" Spacing="12" Margin="0,4,0,0">
                                            <Label Text="{Binding Language}" TextColor="{StaticResource AccentColor}" FontSize="12"/>
                                            <Label Text="{Binding Stars, StringFormat='Stars: {0}'}" TextColor="{StaticResource YellowColor}" FontSize="12"/>
                                            <Label Text="{Binding SizeKb, StringFormat='{0} KB'}" TextColor="{StaticResource TextMutedColor}" FontSize="12"/>
                                        </HorizontalStackLayout>
                                        <HorizontalStackLayout Grid.Row="3" Spacing="6" Margin="0,6,0,0">
                                            <Button Text="Browse" FontSize="11" HeightRequest="30" Padding="8,0"
                                                    BackgroundColor="{StaticResource AccentColor}" TextColor="#1A1610"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:GitViewModel}}, Path=BrowseRepoCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            <Button Text="Download" FontSize="11" HeightRequest="30" Padding="8,0"
                                                    BackgroundColor="{StaticResource GreenColor}" TextColor="#1A1610"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:GitViewModel}}, Path=DownloadRepoCommand}"
                                                    CommandParameter="{Binding .}"/>
                                        </HorizontalStackLayout>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- File Browser -->
                <VerticalStackLayout IsVisible="False">
                    <VerticalStackLayout.Triggers>
                        <DataTrigger TargetType="VerticalStackLayout" Binding="{Binding SelectedTab}" Value="Browse">
                            <Setter Property="IsVisible" Value="True"/>
                        </DataTrigger>
                    </VerticalStackLayout.Triggers>
                    <CollectionView ItemsSource="{Binding CurrentFiles}">
                        <CollectionView.Header>
                            <HorizontalStackLayout Spacing="4" Margin="0,4">
                                <Button Text="Back" FontSize="11" HeightRequest="28" Padding="6,0"
                                        BackgroundColor="{StaticResource SurfaceLightColor}" TextColor="{StaticResource TextColor}"
                                        Command="{Binding GoBackCommand}"/>
                                <Label Text="{Binding CurrentPath, StringFormat='/{0}'}" TextColor="{StaticResource TextMutedColor}"
                                       FontSize="12" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </CollectionView.Header>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:GitFileItem">
                                <Frame BackgroundColor="{StaticResource SurfaceColor}" CornerRadius="6"
                                       Padding="10" Margin="0,2" BorderColor="Transparent">
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:GitViewModel}}, Path=OpenFileCommand}"
                                                             CommandParameter="{Binding .}"/>
                                    </Frame.GestureRecognizers>
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding Type, StringFormat='[{0}]'}" TextColor="{StaticResource AccentColor}" FontSize="12" WidthRequest="40"/>
                                        <Label Text="{Binding Name}" TextColor="{StaticResource TextColor}" FontSize="14"/>
                                        <Label Text="{Binding Size, StringFormat='{0} B'}" TextColor="{StaticResource TextMutedColor}" FontSize="11"
                                               HorizontalOptions="EndAndExpand"/>
                                    </HorizontalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- File Content -->
                    <Frame BackgroundColor="{StaticResource SurfaceColor}" CornerRadius="8"
                           Padding="12" BorderColor="Transparent"
                           IsVisible="{Binding FileContent, Converter={StaticResource IsNotNullOrEmptyConverter}}">
                        <ScrollView>
                            <Label Text="{Binding FileContent}" TextColor="{StaticResource TextColor}"
                                   FontSize="11" FontFamily="monospace"/>
                        </ScrollView>
                    </Frame>
                </VerticalStackLayout>

                <!-- Local Repos -->
                <VerticalStackLayout IsVisible="False">
                    <VerticalStackLayout.Triggers>
                        <DataTrigger TargetType="VerticalStackLayout" Binding="{Binding SelectedTab}" Value="Local">
                            <Setter Property="IsVisible" Value="True"/>
                        </DataTrigger>
                    </VerticalStackLayout.Triggers>
                    <CollectionView ItemsSource="{Binding LocalRepos}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:GitRepoInfo">
                                <Frame BackgroundColor="{StaticResource SurfaceColor}" CornerRadius="8"
                                       Padding="12" Margin="0,3" BorderColor="Transparent">
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                        <Label Text="{Binding Name}" TextColor="{StaticResource TextColor}" FontSize="15" FontAttributes="Bold"/>
                                        <Label Grid.Row="1" Text="{Binding SizeKb, StringFormat='{0} KB'}" TextColor="{StaticResource TextMutedColor}" FontSize="12"/>
                                        <Button Grid.RowSpan="2" Grid.Column="1" Text="Delete" FontSize="11" HeightRequest="30" Padding="8,0"
                                                BackgroundColor="{StaticResource RedColor}" TextColor="White"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:GitViewModel}}, Path=DeleteLocalRepoCommand}"
                                                CommandParameter="{Binding .}"/>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- Download Progress -->
                <Frame BackgroundColor="{StaticResource SurfaceColor}" CornerRadius="8" Padding="12"
                       IsVisible="{Binding IsDownloading}" BorderColor="Transparent">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Downloading..." TextColor="{StaticResource AccentColor}"/>
                        <ProgressBar Progress="{Binding DownloadProgress}" ProgressColor="{StaticResource AccentColor}"/>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
