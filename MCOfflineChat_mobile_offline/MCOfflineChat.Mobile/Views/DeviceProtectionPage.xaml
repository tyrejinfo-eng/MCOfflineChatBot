<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MCOfflineChat.Mobile.ViewModels"
             xmlns:services="clr-namespace:MCOfflineChat.Mobile.Services"
             x:Class="MCOfflineChat.Mobile.Views.DeviceProtectionPage"
             x:DataType="vm:DeviceProtectionViewModel"
             BackgroundColor="{StaticResource BackgroundColor}"
             Title="Device Protection">
    <Grid RowDefinitions="Auto,Auto,*" Padding="16">
        <VerticalStackLayout Grid.Row="0" Spacing="8">
            <Label Text="DEVICE PROTECTION" Style="{StaticResource NeonTitleLabel}" Margin="0,4,0,0"/>
            <Label Text="{Binding StatusText}" TextColor="{StaticResource TextMutedColor}" FontSize="13"/>
            <Button Text="Scan for Access" Command="{Binding ScanCommand}"
                    IsEnabled="{Binding IsScanning, Converter={StaticResource InvertedBoolConverter}}"
                    Style="{StaticResource PrimaryButton}" HeightRequest="40"/>
            <ActivityIndicator IsRunning="{Binding IsScanning}" IsVisible="{Binding IsScanning}"
                             Color="{StaticResource AccentColor}" HeightRequest="20"/>
        </VerticalStackLayout>

        <!-- Stats -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="0,8">
            <Frame BackgroundColor="{StaticResource SurfaceColor}" CornerRadius="8" Padding="12" Margin="0,0,4,0" BorderColor="Transparent">
                <VerticalStackLayout HorizontalOptions="Center">
                    <Label Text="{Binding MicAccessCount}" TextColor="{StaticResource RedColor}" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center"/>
                    <Label Text="Microphone Access" TextColor="{StaticResource TextMutedColor}" FontSize="12" HorizontalOptions="Center"/>
                    <Button Text="Manage" FontSize="11" HeightRequest="30" Padding="8,0" Margin="0,6,0,0"
                            BackgroundColor="{StaticResource AccentColor}" TextColor="#1A1610"
                            Command="{Binding OpenMicSettingsCommand}"/>
                </VerticalStackLayout>
            </Frame>
            <Frame Grid.Column="1" BackgroundColor="{StaticResource SurfaceColor}" CornerRadius="8" Padding="12" Margin="4,0,0,0" BorderColor="Transparent">
                <VerticalStackLayout HorizontalOptions="Center">
                    <Label Text="{Binding CamAccessCount}" TextColor="{StaticResource RedColor}" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center"/>
                    <Label Text="Camera Access" TextColor="{StaticResource TextMutedColor}" FontSize="12" HorizontalOptions="Center"/>
                    <Button Text="Manage" FontSize="11" HeightRequest="30" Padding="8,0" Margin="0,6,0,0"
                            BackgroundColor="{StaticResource AccentColor}" TextColor="#1A1610"
                            Command="{Binding OpenCamSettingsCommand}"/>
                </VerticalStackLayout>
            </Frame>
        </Grid>

        <!-- Tab content: Microphone apps list -->
        <ScrollView Grid.Row="2">
            <VerticalStackLayout Spacing="4">
                <Label Text="Apps with Microphone Permission" TextColor="{StaticResource AccentColor}" FontAttributes="Bold" Margin="0,8,0,4"/>
                <CollectionView ItemsSource="{Binding MicrophoneApps}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="services:DeviceProtectionService+AppAccessInfo">
                            <Frame BackgroundColor="{StaticResource SurfaceColor}" CornerRadius="8"
                                   Padding="10" Margin="0,2" BorderColor="Transparent">
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <VerticalStackLayout>
                                        <Label Text="{Binding AppName}" TextColor="{StaticResource TextColor}" FontSize="14"/>
                                        <Label Text="{Binding PackageName}" TextColor="{StaticResource TextMutedColor}" FontSize="10"/>
                                    </VerticalStackLayout>
                                    <Button Grid.Column="1" Text="Kill" FontSize="10" HeightRequest="28" Padding="6,0" Margin="4,0"
                                            BackgroundColor="{StaticResource RedColor}" TextColor="White"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DeviceProtectionViewModel}}, Path=KillAppCommand}"
                                            CommandParameter="{Binding .}"/>
                                    <Button Grid.Column="2" Text="Revoke" FontSize="10" HeightRequest="28" Padding="6,0"
                                            BackgroundColor="{StaticResource SurfaceLightColor}" TextColor="{StaticResource TextColor}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DeviceProtectionViewModel}}, Path=ManagePermissionsCommand}"
                                            CommandParameter="{Binding .}"/>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="Apps with Camera Permission" TextColor="{StaticResource AccentColor}" FontAttributes="Bold" Margin="0,12,0,4"/>
                <CollectionView ItemsSource="{Binding CameraApps}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="services:DeviceProtectionService+AppAccessInfo">
                            <Frame BackgroundColor="{StaticResource SurfaceColor}" CornerRadius="8"
                                   Padding="10" Margin="0,2" BorderColor="Transparent">
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <VerticalStackLayout>
                                        <Label Text="{Binding AppName}" TextColor="{StaticResource TextColor}" FontSize="14"/>
                                        <Label Text="{Binding PackageName}" TextColor="{StaticResource TextMutedColor}" FontSize="10"/>
                                    </VerticalStackLayout>
                                    <Button Grid.Column="1" Text="Kill" FontSize="10" HeightRequest="28" Padding="6,0" Margin="4,0"
                                            BackgroundColor="{StaticResource RedColor}" TextColor="White"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DeviceProtectionViewModel}}, Path=KillAppCommand}"
                                            CommandParameter="{Binding .}"/>
                                    <Button Grid.Column="2" Text="Revoke" FontSize="10" HeightRequest="28" Padding="6,0"
                                            BackgroundColor="{StaticResource SurfaceLightColor}" TextColor="{StaticResource TextColor}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DeviceProtectionViewModel}}, Path=ManagePermissionsCommand}"
                                            CommandParameter="{Binding .}"/>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
