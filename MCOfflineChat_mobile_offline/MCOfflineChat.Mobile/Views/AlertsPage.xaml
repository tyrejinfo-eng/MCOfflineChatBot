<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MCOfflineChat.Mobile.ViewModels"
             xmlns:models="clr-namespace:MCOfflineChat.Mobile.Models"
             x:Class="MCOfflineChat.Mobile.Views.AlertsPage"
             x:DataType="vm:AlertsViewModel"
             Title="Security Alerts">

    <Grid RowDefinitions="Auto,Auto,*" Padding="16" RowSpacing="12">

        <!-- Header Stats -->
        <Frame Style="{StaticResource CardFrame}" Grid.Row="0">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                <Label Text="Security Alerts"
                       Style="{StaticResource TitleLabel}"
                       HorizontalTextAlignment="Start"
                       Grid.ColumnSpan="2" />
                <Label Text="{Binding StatusMessage}"
                       Style="{StaticResource MutedLabel}"
                       Grid.Row="1" />
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Grid.Row="1" Grid.Column="1"
                                   HeightRequest="20" WidthRequest="20" />
            </Grid>
        </Frame>

        <!-- Filter Bar -->
        <HorizontalStackLayout Grid.Row="1" Spacing="8" HorizontalOptions="Center">
            <Picker Title="Filter"
                    ItemsSource="{Binding FilterOptions}"
                    SelectedItem="{Binding SelectedFilter}"
                    TextColor="{StaticResource TextColor}"
                    TitleColor="{StaticResource TextMutedColor}"
                    BackgroundColor="{StaticResource SurfaceColor}"
                    WidthRequest="140" />
            <Label Text="{Binding TotalAlerts, StringFormat='{0} total'}"
                   TextColor="{StaticResource TextMutedColor}"
                   VerticalOptions="Center" FontSize="13" />
            <Label Text="{Binding CriticalCount, StringFormat='{0} critical'}"
                   TextColor="{StaticResource RedColor}"
                   VerticalOptions="Center" FontSize="13" />
        </HorizontalStackLayout>

        <!-- Alert List -->
        <RefreshView Grid.Row="2"
                     Command="{Binding RefreshAlertsCommand}"
                     IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Alerts}"
                            SelectionMode="None">
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center"
                                         Padding="40" Spacing="8">
                        <Label Text="No Alerts"
                               TextColor="{StaticResource GreenColor}"
                               FontSize="20" FontAttributes="Bold"
                               HorizontalTextAlignment="Center" />
                        <Label Text="All clear — no security alerts detected."
                               TextColor="{StaticResource TextMutedColor}"
                               FontSize="14" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:SecurityAlertItem">
                        <Frame Style="{StaticResource CardFrame}" Margin="0,4">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AlertsViewModel}}, Path=ViewAlertDetailCommand}"
                                    CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>
                            <Grid ColumnDefinitions="6,*,Auto" ColumnSpacing="12">
                                <!-- Severity indicator -->
                                <BoxView CornerRadius="3"
                                         WidthRequest="6"
                                         Color="{Binding SeverityColor}"
                                         VerticalOptions="Fill" />

                                <!-- Content -->
                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <Label Text="{Binding Title}"
                                           TextColor="{StaticResource TextColor}"
                                           FontSize="15" FontAttributes="Bold"
                                           LineBreakMode="TailTruncation" />
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding Severity}"
                                               TextColor="{Binding SeverityColor}"
                                               FontSize="12" FontAttributes="Bold" />
                                        <Label Text="{Binding ScoreDisplay}"
                                               TextColor="{StaticResource TextMutedColor}"
                                               FontSize="12" />
                                        <Label Text="{Binding EventType}"
                                               TextColor="{StaticResource TextMutedColor}"
                                               FontSize="12" />
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding TimestampDisplay}"
                                           TextColor="{StaticResource TextMutedColor}"
                                           FontSize="11" />
                                </VerticalStackLayout>

                                <!-- Response Action -->
                                <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding ResponseAction}"
                                           TextColor="{StaticResource AccentColor}"
                                           FontSize="11" HorizontalTextAlignment="End" />
                                    <Label Text="{Binding HostId}"
                                           TextColor="{StaticResource TextMutedColor}"
                                           FontSize="10" HorizontalTextAlignment="End"
                                           LineBreakMode="TailTruncation"
                                           MaximumWidthRequest="80" />
                                </VerticalStackLayout>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>
