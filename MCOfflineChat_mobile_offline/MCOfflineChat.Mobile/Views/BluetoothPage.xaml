<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MCOfflineChat.Mobile.ViewModels"
             xmlns:models="clr-namespace:MCOfflineChat.Mobile.Models"
             x:Class="MCOfflineChat.Mobile.Views.BluetoothPage"
             x:DataType="vm:BluetoothViewModel"
             BackgroundColor="{StaticResource BackgroundColor}"
             Title="Bluetooth Scanner">
    <ScrollView>
        <VerticalStackLayout Spacing="10" Padding="16">

            <!-- Neon Title -->
            <Label Text="BLUETOOTH" Style="{StaticResource NeonTitleLabel}" Margin="0,4,0,0"/>

            <!-- Status Bar -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                <Label Text="{Binding StatusText}" TextColor="{StaticResource TextMutedColor}" FontSize="12"
                       VerticalOptions="Center" LineBreakMode="TailTruncation"/>
                <ActivityIndicator Grid.Column="1" IsRunning="{Binding IsScanning}" IsVisible="{Binding IsScanning}"
                                   Color="{StaticResource AccentColor}" HeightRequest="16" WidthRequest="16"/>
            </Grid>

            <!-- Scan Controls -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                <Button Text="Scan" Command="{Binding StartScanCommand}"
                        IsVisible="{Binding IsScanning, Converter={StaticResource InvertedBoolConverter}}"
                        BackgroundColor="{StaticResource AccentColor}" TextColor="#1A1610"
                        FontSize="13" FontAttributes="Bold" HeightRequest="40" CornerRadius="8"/>
                <Button Grid.Column="1" Text="Stop" Command="{Binding StopScanCommand}"
                        IsVisible="{Binding IsScanning}"
                        BackgroundColor="{StaticResource RedColor}" TextColor="White"
                        FontSize="13" FontAttributes="Bold" HeightRequest="40" CornerRadius="8"/>
                <Button Grid.Column="2"
                        Text="{Binding IsBroadcasting, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Stop BLE|Start BLE'}"
                        Command="{Binding ToggleBroadcastCommand}"
                        BackgroundColor="{Binding IsBroadcasting, Converter={StaticResource BoolToColorConverter}}"
                        TextColor="White"
                        FontSize="11" FontAttributes="Bold" HeightRequest="40" CornerRadius="8"/>
            </Grid>

            <!-- BLE Broadcast Status -->
            <Frame BackgroundColor="{StaticResource SurfaceColor}" CornerRadius="10" Padding="10"
                   BorderColor="Transparent" HasShadow="False"
                   IsVisible="{Binding IsBroadcasting}">
                <HorizontalStackLayout Spacing="8">
                    <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="5"
                             Color="{StaticResource GreenColor}"/>
                    <Label Text="BLE Broadcasting - MC Offline Chat Beacon Active"
                           TextColor="{StaticResource GreenColor}" FontSize="12" FontAttributes="Bold"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Frame>

            <!-- ═══ DISCOVERED DEVICES ═══ -->
            <Frame BackgroundColor="{StaticResource SurfaceColor}" CornerRadius="12" Padding="12"
                   BorderColor="Transparent" HasShadow="False">
                <VerticalStackLayout Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Discovered Devices" TextColor="{StaticResource AccentColor}"
                               FontSize="16" FontAttributes="Bold" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="{Binding DeviceCount, StringFormat='{0} found'}"
                               TextColor="{StaticResource TextMutedColor}" FontSize="12" VerticalOptions="Center"/>
                    </Grid>

                    <CollectionView ItemsSource="{Binding Devices}" HeightRequest="300">
                        <CollectionView.EmptyView>
                            <Label Text="No devices found. Tap Scan to search for BLE devices."
                                   TextColor="{StaticResource TextMutedColor}" FontSize="13"
                                   HorizontalTextAlignment="Center" Margin="0,40,0,0"/>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:BluetoothDeviceInfo">
                                <Frame BackgroundColor="{StaticResource CardColor}" CornerRadius="8"
                                       Padding="10" Margin="0,2" BorderColor="Transparent" HasShadow="False">
                                    <VerticalStackLayout Spacing="4">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Text="{Binding Name}" TextColor="{StaticResource TextColor}"
                                                   FontSize="14" FontAttributes="Bold"/>
                                            <Label Grid.Column="1" Text="{Binding SignalStrength}"
                                                   TextColor="{StaticResource AccentColor}" FontSize="11"
                                                   VerticalOptions="Center"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="10">
                                            <Label Text="{Binding DeviceType}" TextColor="{StaticResource TextMutedColor}" FontSize="11"/>
                                            <Label Grid.Column="1" Text="{Binding Rssi, StringFormat='{0} dBm'}"
                                                   TextColor="{StaticResource TextMutedColor}" FontSize="11"/>
                                            <Label Grid.Column="2" Text="{Binding ThreatLevel}" FontSize="11"
                                                   TextColor="{StaticResource GreenColor}"/>
                                            <Label Grid.Column="3" Text="{Binding IsConnected, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Connected|'}"
                                                   TextColor="{StaticResource GreenColor}" FontSize="11"
                                                   HorizontalTextAlignment="End"/>
                                        </Grid>
                                        <HorizontalStackLayout Spacing="6" Margin="0,4,0,0">
                                            <Button Text="Analyze" FontSize="10" HeightRequest="30" Padding="8,0"
                                                    BackgroundColor="{StaticResource AccentColor}" TextColor="#1A1610"
                                                    CornerRadius="6"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:BluetoothViewModel}}, Path=AnalyzeDeviceCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            <Button Text="Connect" FontSize="10" HeightRequest="30" Padding="8,0"
                                                    BackgroundColor="{StaticResource SurfaceLightColor}" TextColor="{StaticResource TextColor}"
                                                    CornerRadius="6"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:BluetoothViewModel}}, Path=ConnectToDeviceCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            <Button Text="Details" FontSize="10" HeightRequest="30" Padding="8,0"
                                                    BackgroundColor="{StaticResource SurfaceLightColor}" TextColor="{StaticResource TextColor}"
                                                    CornerRadius="6"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:BluetoothViewModel}}, Path=ShowDeviceDetailsCommand}"
                                                    CommandParameter="{Binding .}"/>
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <!-- ═══ BLE BROADCAST MESSAGE ═══ -->
            <Frame BackgroundColor="{StaticResource SurfaceColor}" CornerRadius="12" Padding="12"
                   BorderColor="Transparent" HasShadow="False">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Broadcast Message via BLE"
                           TextColor="{StaticResource AccentColor}" FontSize="14" FontAttributes="Bold"/>
                    <Label Text="Send a message to all nearby MC Offline Chat BLE devices."
                           TextColor="{StaticResource TextMutedColor}" FontSize="11"/>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Entry Text="{Binding EmergencyMessage}" Placeholder="Enter broadcast message..."
                               PlaceholderColor="{StaticResource TextMutedColor}"
                               TextColor="{StaticResource TextColor}"
                               BackgroundColor="{StaticResource SurfaceLightColor}"
                               FontSize="13"/>
                        <Button Grid.Column="1" Text="Send"
                                Command="{Binding BroadcastEmergencyCommand}"
                                BackgroundColor="{StaticResource AccentColor}" TextColor="#1A1610"
                                HeightRequest="40" WidthRequest="70" FontSize="13" FontAttributes="Bold"
                                CornerRadius="8"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Analysis Result Overlay -->
            <Frame BackgroundColor="#CC0D0A06" CornerRadius="12" Padding="16"
                   IsVisible="{Binding IsAnalyzing}" HorizontalOptions="Center"
                   WidthRequest="300" BorderColor="Transparent" HasShadow="False">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Analyzing Device..." TextColor="{StaticResource AccentColor}" FontAttributes="Bold"/>
                    <ActivityIndicator IsRunning="True" Color="{StaticResource AccentColor}"/>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
