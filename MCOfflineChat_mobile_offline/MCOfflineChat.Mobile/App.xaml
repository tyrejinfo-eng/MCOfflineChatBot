<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:MCOfflineChat.Mobile.Converters"
             x:Class="MCOfflineChat.Mobile.App">
    <Application.Resources>
        <ResourceDictionary>

            <!-- Converters -->
            <converters:BoolToColorConverter x:Key="BoolToColorConverter" />
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <converters:IsNotNullOrEmptyConverter x:Key="IsNotNullOrEmptyConverter" />
            <converters:BoolToStringConverter x:Key="BoolToStringConverter" />
            <converters:IsNotZeroConverter x:Key="IsNotZeroConverter" />

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- MC Offline Chat Dark Theme - Matches Desktop V1.1.36          -->
            <!-- ═══════════════════════════════════════════════════════════ -->

            <!-- Core Colors - Matched to Desktop DarkTheme.xaml -->
            <Color x:Key="PrimaryColor">#D4A017</Color>
            <Color x:Key="BackgroundColor">#1A1610</Color>
            <Color x:Key="SurfaceColor">#211C14</Color>
            <Color x:Key="SurfaceLightColor">#3A3020</Color>
            <Color x:Key="CardColor">#3D2E1A</Color>
            <Color x:Key="TextColor">#FFFFFF</Color>
            <Color x:Key="TextMutedColor">#B0B0B0</Color>
            <Color x:Key="AccentColor">#FFD700</Color>
            <Color x:Key="AccentDarkColor">#FF8C00</Color>
            <Color x:Key="GreenColor">#00E676</Color>
            <Color x:Key="RedColor">#FF1744</Color>
            <Color x:Key="YellowColor">#FFC107</Color>
            <Color x:Key="OverlayColor">#0D0A06</Color>
            <Color x:Key="BorderColor">#3A3020</Color>

            <!-- Neon Glow Colors for retro 80s titles -->
            <Color x:Key="NeonCyanColor">#00FFFF</Color>
            <Color x:Key="NeonPinkColor">#FF00FF</Color>
            <Color x:Key="NeonGoldColor">#FFD700</Color>
            <Color x:Key="NeonGlowColor">#D4A01780</Color>

            <!-- Styles -->
            <Style TargetType="Page" ApplyToDerivedTypes="True">
                <Setter Property="BackgroundColor" Value="{StaticResource BackgroundColor}" />
            </Style>

            <Style TargetType="Shell" ApplyToDerivedTypes="True">
                <Setter Property="Shell.BackgroundColor" Value="{StaticResource SurfaceColor}" />
                <Setter Property="Shell.ForegroundColor" Value="{StaticResource TextColor}" />
                <Setter Property="Shell.TitleColor" Value="{StaticResource TextColor}" />
                <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource SurfaceColor}" />
                <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource AccentColor}" />
                <Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource TextMutedColor}" />
                <Setter Property="Shell.TabBarTitleColor" Value="{StaticResource AccentColor}" />
            </Style>

            <!-- Neon Title Style - 80s Retro animated glow -->
            <Style TargetType="Label" x:Key="NeonTitleLabel">
                <Setter Property="TextColor" Value="{StaticResource NeonGoldColor}" />
                <Setter Property="FontSize" Value="28" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="HorizontalTextAlignment" Value="Center" />
                <Setter Property="Shadow">
                    <Setter.Value>
                        <Shadow Brush="{StaticResource NeonGoldColor}" Offset="0,0" Radius="15" Opacity="0.8" />
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="Label" x:Key="TitleLabel">
                <Setter Property="TextColor" Value="{StaticResource TextColor}" />
                <Setter Property="FontSize" Value="24" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="HorizontalTextAlignment" Value="Center" />
            </Style>

            <Style TargetType="Label" x:Key="SubtitleLabel">
                <Setter Property="TextColor" Value="{StaticResource TextMutedColor}" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="HorizontalTextAlignment" Value="Center" />
            </Style>

            <Style TargetType="Label" x:Key="BodyLabel">
                <Setter Property="TextColor" Value="{StaticResource TextColor}" />
                <Setter Property="FontSize" Value="16" />
            </Style>

            <Style TargetType="Label" x:Key="MutedLabel">
                <Setter Property="TextColor" Value="{StaticResource TextMutedColor}" />
                <Setter Property="FontSize" Value="12" />
            </Style>

            <Style TargetType="Entry" x:Key="DarkEntry">
                <Setter Property="BackgroundColor" Value="{StaticResource SurfaceColor}" />
                <Setter Property="TextColor" Value="{StaticResource TextColor}" />
                <Setter Property="PlaceholderColor" Value="{StaticResource TextMutedColor}" />
                <Setter Property="FontSize" Value="16" />
            </Style>

            <Style TargetType="Button" x:Key="PrimaryButton">
                <Setter Property="BackgroundColor" Value="{StaticResource AccentColor}" />
                <Setter Property="TextColor" Value="{StaticResource OverlayColor}" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="HeightRequest" Value="48" />
            </Style>

            <Style TargetType="Button" x:Key="SecondaryButton">
                <Setter Property="BackgroundColor" Value="{StaticResource SurfaceColor}" />
                <Setter Property="TextColor" Value="{StaticResource AccentColor}" />
                <Setter Property="BorderColor" Value="{StaticResource AccentColor}" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="HeightRequest" Value="48" />
            </Style>

            <Style TargetType="Button" x:Key="DangerButton">
                <Setter Property="BackgroundColor" Value="{StaticResource RedColor}" />
                <Setter Property="TextColor" Value="#FFFFFF" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="HeightRequest" Value="48" />
            </Style>

            <Style TargetType="Frame" x:Key="CardFrame">
                <Setter Property="BackgroundColor" Value="{StaticResource CardColor}" />
                <Setter Property="BorderColor" Value="Transparent" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="HasShadow" Value="False" />
            </Style>

            <Style TargetType="ActivityIndicator">
                <Setter Property="Color" Value="{StaticResource AccentColor}" />
            </Style>

            <Style TargetType="ProgressBar">
                <Setter Property="ProgressColor" Value="{StaticResource AccentColor}" />
            </Style>

            <Style TargetType="Switch">
                <Setter Property="OnColor" Value="{StaticResource GreenColor}" />
                <Setter Property="ThumbColor" Value="{StaticResource TextColor}" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
